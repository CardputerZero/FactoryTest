#!/bin/sh
set -e

PRODUCT_GROUP="@APP_PRODUCT_GROUP@"

if [ "$1" = "configure" ]; then
    if ! getent group "$PRODUCT_GROUP" >/dev/null 2>&1; then
        if ! groupadd --system "$PRODUCT_GROUP"; then
            echo "Warning: failed to create product group $PRODUCT_GROUP; group-based permissions may be unavailable" >&2
        fi
    fi

    # Runtime account membership belongs to image provisioning or first-boot setup.
    # Package installation may run in a chroot with an unrelated SUDO_USER.

fi

exit 0
